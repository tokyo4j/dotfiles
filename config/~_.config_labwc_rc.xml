<labwc_config>
  <focus followMouse="yes" followMouseRequiresMovement="yes" raiseOnFocus="no" />

  <snapping range="20" />

  <keyboard repeatRate="25" repeatDelay="600">
    <keybind key="A-Tab">
      <action name="NextWindow" />
    </keybind>
    <keybind key="W-s">
      <action name="Execute" command="alacritty" />
    </keybind>
    <keybind key="W-a">
      <action name="Execute" command="fuzzel" />
    </keybind>
    <keybind key="A-F4">
      <action name="Close" />
    </keybind>
    <keybind key="W-Tab">
      <action name="ToggleMaximize" />
    </keybind>
    <keybind key="W-h">
      <action name="SnapToEdge" direction="left" />
    </keybind>
    <keybind key="W-l">
      <action name="SnapToEdge" direction="right" />
    </keybind>
    <keybind key="W-k">
      <action name="SnapToEdge" direction="up" />
    </keybind>
    <keybind key="W-j">
      <action name="SnapToEdge" direction="down" />
    </keybind>
    <keybind key="XF86_AudioLowerVolume">
      <action name="Execute" command="pactl set-sink-volume @DEFAULT_SINK@ -2dB" />
    </keybind>
    <keybind key="XF86_AudioRaiseVolume">
      <action name="Execute" command="pactl set-sink-volume @DEFAULT_SINK@ +2dB" />
    </keybind>
    <keybind key="XF86_AudioMute">
      <action name="Execute" command="pactl set-sink-mute @DEFAULT_SINK@ toggle" />
    </keybind>
    <keybind key="XF86_AudioMicMute">
      <action name="Execute" command="pactl set-source-mute @DEFAULT_SOURCE@ toggle" />
    </keybind>
    <keybind key="XF86_MonBrightnessUp">
      <action name="Execute" command="brightnessctl set +3%" />
    </keybind>
    <keybind key="XF86_MonBrightnessDown">
      <action name="Execute" command="brightnessctl set 3%-" />
    </keybind>
    <keybind key="Print">
      <action name="Execute" command="grim" />
    </keybind>
  </keyboard>

  <mouse doubleClickTime="200">
    <default />
    <context name="Frame">
      <mousebind button="W-Left" action="Drag">
        <action name="Raise" />
        <action name="Move" />
      </mousebind>
      <mousebind button="W-Right" action="Drag">
        <action name="Resize" />
      </mousebind>

      <mousebind button="A-Left" action="Press" />
      <mousebind button="A-Left" action="Drag" />
      <mousebind button="A-Right" action="Press" />
      <mousebind button="A-Right" action="Drag" />
    </context>
  </mouse>

  <libinput>
    <device category="touchpad" naturalScroll="yes" tapAndDrag="no" />
  </libinput>

  <windowSwitcher>
    <fields>
      <field content="type" width="15%" />
      <field content="title" width="85%" />
    </fields>
  </windowSwitcher>
</labwc_config>
