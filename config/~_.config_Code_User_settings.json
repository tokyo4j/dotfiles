{
  "json.validate.enable": false,
  "editor.formatOnSave": true,
  "explorer.sortOrder": "type",
  "editor.detectIndentation": false,
  "terminal.integrated.defaultProfile.linux": "fish",
  "workbench.colorTheme": "Monokai",
  "editor.tabSize": 4,
  "npm.packageManager": "pnpm",
  "editor.fastScrollSensitivity": 5,
  "terminal.integrated.cursorBlinking": true,
  "editor.fontFamily": "monospace, 'Font Awesome 6 Brands Regular', 'Font Awesome 6 Free Solid', 'Font Awesome 6 Free Regular'",
  "svelte.enable-ts-plugin": true,
  "editor.multiCursorModifier": "ctrlCmd",
  "hediet.vscode-drawio.resizeImages": null,
  "hediet.vscode-drawio.theme": "min",
  "editor.inlineSuggest.enabled": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "window.zoomLevel": 1,
  "C_Cpp.default.cStandard": "gnu17",
  "C_Cpp.default.cppStandard": "gnu++17",
  "rust-analyzer.server.path": "/usr/bin/rust-analyzer",
  "cscopeCode.auto": false,
  "remote.SSH.useLocalServer": false,
  "zig.zigPath": "/usr/bin/zig",
  "zig.zls.path": "/usr/bin/zls",
  "nim.nimprettyIndent": 2,
  "sqltools.autoOpenSessionFiles": false,
  "remote.SSH.remotePlatform": {
    "ubuntu": "linux",
    "fuji": "linux"
  },
  "workbench.colorCustomizations": {
    "[Monokai]": {
      "editorInlayHint.foreground": "#868686f0",
      "editorInlayHint.background": "#18181800",
      "editorInlayHint.typeForeground": "#486148f0",
      "editorInlayHint.parameterForeground": "#486148f0"
    }
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[blade]": {
    "editor.defaultFormatter": "amirmarmul.laravel-blade-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[c]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "[cpp]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
    "editor.tabSize": 2
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "[php]": {
    "editor.defaultFormatter": "bmewburn.vscode-intelephense-client"
  }
}
